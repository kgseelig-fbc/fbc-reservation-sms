# ADP API Credentials (from ADP Marketplace developer portal)
ADP_CLIENT_ID=your-client-id
ADP_CLIENT_SECRET=your-client-secret

# Mutual TLS certificate paths (required by ADP for all API calls)
ADP_SSL_CERT_PATH=./certs/cert.pem
ADP_SSL_KEY_PATH=./certs/key.pem

# ADP API endpoints (defaults shown - override for sandbox/testing)
ADP_API_BASE=https://api.adp.com
ADP_TOKEN_URL=https://accounts.adp.com/auth/oauth/v2/token
